# ─── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins (the Flutter app / web checkout)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Database ──────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/hoppr_escrow

# ─── Auth / JWT ────────────────────────────────────────────────────────────
# Generate strong secrets, e.g.  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ─── Escrow.com API ────────────────────────────────────────────────────────
ESCROW_API_URL=https://api.escrow.com/2017-09-01
ESCROW_PAY_URL=https://api.escrow.com/integration/pay/2018-03-31
ESCROW_EMAIL=your_escrow_account_email
ESCROW_API_KEY=your_escrow_api_key
# Shared secret used to verify inbound Escrow.com webhooks (HMAC)
ESCROW_WEBHOOK_SECRET=replace_with_webhook_signing_secret

# ─── Business rules ────────────────────────────────────────────────────────
# Trust-protection fee rate (1.5% — must match the Flutter PaymentDraft.trustRate)
TRUST_FEE_RATE=0.015
# Default delivery fee in NGN (matches PaymentDraft.deliveryFee default)
DEFAULT_DELIVERY_FEE_NGN=7500
# Delivery confirmation geofence radius, in metres
DELIVERY_GEOFENCE_METRES=200
# Delivery OTP validity, in days
DELIVERY_OTP_TTL_DAYS=7
